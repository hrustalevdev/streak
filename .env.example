# URL mock API (менять не нужно при локальном запуске)
API_BASE_URL=http://localhost:3000

# --- LLM-провайдер ---
# ollama (по умолчанию) — локальная модель через Ollama
# openrouter — облачная модель через OpenRouter
LLM_PROVIDER=ollama

# Настройки для LLM_PROVIDER=ollama
# OLLAMA_BASE_URL:
#   - npm run agent (без Docker) → http://localhost:11434/v1
#   - через Docker, Ollama на этой же машине → http://host.docker.internal:11434/v1
#   - через Docker, Ollama на другой машине в сети → http://<IP>:11434/v1
OLLAMA_BASE_URL=http://localhost:11434/v1
# Любая модель с поддержкой tool calling подойдёт — укажите свою, если она уже скачана.
# qwen3.5:9b — наша протестированная рекомендация (см. docs/progress.md)
OLLAMA_MODEL=qwen3.5:9b

# Настройки для LLM_PROVIDER=openrouter
# Получить на openrouter.ai → Keys (бесплатно, без карты)
OPENROUTER_API_KEY=your_key_here
